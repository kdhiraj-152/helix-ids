{
  "problem": "HELIX class-4 post-hoc control exhibited an inactivity regime in adaptive-coupled operation, producing zero overrides despite non-zero class-4 prediction mass.",
  "hypothesis": "Combining fixed and adaptive control thresholds should activate selective class-4 overrides under low-confidence margins and produce controllable behavior without retraining.",
  "method": {
    "name": "helix layer",
    "type": "post-hoc control layer",
    "mechanism": "At inference, compute margin from logits, evaluate control thresholds for class-4 top predictions, and optionally replace argmax with second-best class.",
    "math_formulation": {
      "margin": "m = top1 - second_max",
      "z_score": "z = (m - mu) / sigma",
      "override_condition": "argmax=4 AND (m < tau_fixed OR z < tau_adaptive)"
    },
    "no_retraining": true
  },
  "experimental_setup": {
    "datasets": [
      "UNSW-NB15 (test)",
      "NSL-KDD (test)"
    ],
    "base_model": "models/helix_full/helix_full_unsw_nb15_best.pt",
    "evaluation_protocol": "in-distribution (UNSW checkpoint on UNSW test) + cross-distribution (UNSW checkpoint on NSL test)",
    "metrics_used": [
      "macro_f1",
      "override_rate",
      "override_count",
      "class4_precision",
      "class4_recall",
      "class4_prediction_ratio",
      "class4_margin_distribution"
    ]
  },
  "ablations": [
    {
      "name": "fixed_tau_only",
      "role": "baseline control"
    },
    {
      "name": "percentile_only",
      "role": "adaptive baseline"
    },
    {
      "name": "online_hybrid",
      "role": "combined but coupled"
    },
    {
      "name": "frozen_z_hybrid",
      "role": "decoupled + normalized final method"
    }
  ],
  "failure_analysis": {
    "failed_method": "online_hybrid",
    "failure_type": "control collapse / inactivity",
    "root_cause": "adaptive threshold coupled to drifting margin distribution",
    "evidence": [
      "online_hybrid override_rate=0.0 on UNSW and NSL",
      "online_hybrid override_count=0 on UNSW and NSL",
      "inactive variants retain identical pre_top1 vs post_pred margin distributions"
    ]
  },
  "intervention": {
    "decoupling": "freeze adaptive threshold from calibration instead of updating online",
    "normalization": "use z-score normalized margin channel to avoid direct coupling to raw margin drift",
    "bug_fixes": [
      "fixed gate uses raw tau positivity"
    ]
  },
