# Python cache and build artifacts
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg-info/
.eggs/
build/
dist/

# Virtual environments
.venv/
.venv*/
venv/

# Tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# Coverage and reports
.coverage
coverage.xml
htmlcov/
*.coverage

# OS/editor noise
.DS_Store
.vscode/
.idea/

# Project runtime artifacts
checkpoints/
# Only ignore top-level model storage and binary artifacts; keep source packages
/models/
**/models/*.pt
**/models/*.pth
results/
outputs/
artifacts/
.code-review-graph/

# Local agent/tooling state
.opencode.json
.mcp.json

# Recycle bin for proven-dead code (archived, not active)
src/helix_ids/_unused/

# Large/local datasets
# Keep dataset manifests/docs in git if needed, ignore bulk files.
data/processed/
data/**/raw/
data/**/raw
data/**/*.csv
data/**/*.npy
data/**/*.npz
data/**/*.parquet
data/**/*.pkl
data/splits/

# Logs
*.log
logs/
session_logs/

# Temporary build artifacts
tmp_artifact/

# Generated database files (cosmic-ray mutation test sessions)
*.db

# Hypothesis test cache
.hypothesis/

# Cleanup analysis artifacts (one-time outputs)
docs/DUPLICATE_AND_SUPERSEDED_ANALYSIS.md
naming_consistency_assessment.md

# Transient artifacts (not committed)
exported_model.pt
exported_model.pt.*
finding-structured.json

# Cleanup reports (one-time)
CLEANUP_REPORT.md

# Cosmic-ray baseline session cache
baseline-freeze-session

# Generated binary artifacts (never commit)
*.pdf
*.docx
*.pptx
docs/figures/*.png

# Benchmark run outputs (gitignored; baseline.reference.json is tracked instead)
/benchmarks/baseline.json
/benchmarks/load_test_results.json
/benchmarks/_tmp/

# Top-level/binary model checkpoints (prevent accidental commits)
*.pt
*.pth
