# Python cache and build artifacts
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg-info/
.eggs/
build/
dist/

# Virtual environments
.venv/
.venv*/
venv/

# Tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# Coverage and reports
.coverage
coverage.xml
htmlcov/
*.coverage

# OS/editor noise
.DS_Store
.vscode/
.idea/

# Project runtime artifacts
checkpoints/
# Only ignore top-level model storage and binary artifacts; keep source packages
/models/
**/models/*.pt
**/models/*.pth
results/
outputs/
artifacts/
.code-review-graph/

# Local agent/tooling state
.opencode.json
.mcp.json

# Recycle bin for proven-dead code (archived, not active)
src/helix_ids/_unused/

# Large/local datasets
# Keep dataset manifests/docs in git if needed, ignore bulk files.
data/**/raw/
data/**/raw
data/**/*.csv
data/**/*.npy
data/**/*.npz
data/**/*.parquet

# Logs
*.log
logs/
session_logs/

# Temporary build artifacts
tmp_artifact/

# Transient artifacts (not committed)
exported_model.pt
exported_model.pt.*
finding-structured.json

# Cleanup reports (one-time)
CLEANUP_REPORT.md
